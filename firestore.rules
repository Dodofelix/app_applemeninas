rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Produtos: leitura pública (formulário), escrita só logado (admin)
    match /products/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    // Clientes: criar sem login (formulário), ler/editar só admin
    match /clients/{docId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
    // Pedidos: criar sem login (formulário), ler/editar só admin
    match /orders/{docId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
    // Saídas do fluxo de caixa: só admin logado
    match /expenses/{docId} {
      allow read, write: if request.auth != null;
    }
    // Configurações: taxas do gateway (settings/gateway) e preços da calculadora de upgrade (settings/calculator).
    match /settings/{docId} {
      allow read, write: if request.auth != null;
    }
  }
}
